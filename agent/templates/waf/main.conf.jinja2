# Generated by Agent from the WAF DocType in Press.
# Do not edit by hand — every change must originate in Press so the
# configuration stays the source-of-truth on the control plane.
#
# Site: {{ site_name }}
# Mode: {{ mode }}
#
# Rule ID ranges:
#   10000-19999  IP allow/block
#   20000-29999  rate limits
#   30000-39999  blocked endpoints
#   40000-49999  blocked parameters
#   50000-59999  (reserved)
#   60000-69999  request size limits
#   100000+      user custom rules

# --- Base engine settings (self-contained, no external Include) ------
SecRequestBodyAccess On
SecResponseBodyAccess Off
SecRequestBodyLimit 134217728
SecRequestBodyNoFilesLimit 1048576
SecDebugLog /dev/null
SecDebugLogLevel 0

SecRuleEngine {{ "On" if mode == "Prevention" else "DetectionOnly" }}

# --- Audit logging ----------------------------------------------------
SecAuditEngine RelevantOnly
SecAuditLog {{ audit_log_path }}
SecAuditLogParts ABIJDEFHZ
SecAuditLogType Serial
SecAuditLogFormat JSON
SecAuditLogRelevantStatus "^(?:5|4(?!04))"

# --- Marker so tooling can detect Agent-managed configs reliably -----
SecMarker WAF_AGENT_MANAGED

{% if ip_rules %}
# --- IP rules ---------------------------------------------------------
{% for rule in ip_rules %}
{% if rule.rule_type == "Allowed" %}
SecRule REMOTE_ADDR "@ipMatch {{ rule.ip }}" "id:{{ 10000 + loop.index0 }},phase:1,allow,nolog,msg:'IP allowlist {{ rule.ip }}'"
{% else %}
SecRule REMOTE_ADDR "@ipMatch {{ rule.ip }}" "id:{{ 11000 + loop.index0 }},phase:1,deny,status:403,log,msg:'IP blocklist {{ rule.ip }}'"
{% endif %}
{% endfor %}
{% endif %}

{% if rate_limits %}
# --- Rate limits ------------------------------------------------------
#
# Uses the verified 3-step decoupled topology for upstream ModSecurity v3.
# 1. Initialize the target collection context.
# 2. Check the active counter value and block immediately if exceeded.
# 3. Increment the counter value if the transaction passes inspection.
#
# All collection references remain lowercase to satisfy parser logic.

{% for rl in rate_limits %}
# Rate Limit Rule {{ loop.index0 }}: {{ rl.key }}{% if rl.endpoint %} for {{ rl.endpoint }}{% endif %}

{%- set base_id = 20000 + (loop.index0 * 3) %}
{%- set limit_key = "RATE_" ~ loop.index0 %}

{%- if rl.key == "IP" %}
    {%- set collection = "ip" %}
    {%- set init = "initcol:ip=%{REMOTE_ADDR}" %}
    {%- set label = "(IP)" %}
{%- elif rl.key == "URI" %}
    {%- set collection = "resource" %}
    {%- set init = "initcol:resource=%{REQUEST_FILENAME}" %}
    {%- set label = "(URI)" %}
{%- elif rl.key == "IP+URI" %}
    {%- set collection = "resource" %}
    {%- set init = "initcol:resource=%{REMOTE_ADDR}_%{REQUEST_FILENAME}" %}
    {%- set label = "(IP+URI)" %}
{%- endif %}

# Step 1: Initialize the collection storage driver context
SecAction \
    "id:{{ base_id }},\
    phase:1,\
    pass,\
    nolog,\
    {{ init }}"

# Step 2: Enforce the block if the counter threshold has already been crossed
{%- if rl.endpoint %}
SecRule REQUEST_FILENAME "@rx {{ rl.endpoint }}" \
    "id:{{ base_id + 1 }},\
    phase:1,\
    deny,\
    status:429,\
    log,\
    t:none,\
    t:normalizePath,\
    msg:'Rate limit {{ rl.rate }}/{{ rl.window }}s exceeded (burst {{ rl.burst }}) {{ label }} (endpoint {{ rl.endpoint }})',\
    chain"
    SecRule {{ collection }}:{{ limit_key }} "@gt {{ rl.rate + rl.burst }}"
{%- else %}
SecRule {{ collection }}:{{ limit_key }} "@gt {{ rl.rate + rl.burst }}" \
    "id:{{ base_id + 1 }},\
    phase:1,\
    deny,\
    status:429,\
    log,\
    msg:'Rate limit {{ rl.rate }}/{{ rl.window }}s exceeded (burst {{ rl.burst }}) {{ label }}'"
{%- endif %}

# Step 3: Increment the matching context counter and reset the expiration timeline
{%- if rl.endpoint %}
SecRule REQUEST_FILENAME "@rx {{ rl.endpoint }}" \
    "id:{{ base_id + 2 }},\
    phase:1,\
    pass,\
    nolog,\
    t:none,\
    t:normalizePath,\
    setvar:{{ collection }}.{{ limit_key }}=+1,\
    expirevar:{{ collection }}.{{ limit_key }}={{ rl.window }}"
{%- else %}
SecAction \
    "id:{{ base_id + 2 }},\
    phase:1,\
    pass,\
    nolog,\
    setvar:{{ collection }}.{{ limit_key }}=+1,\
    expirevar:{{ collection }}.{{ limit_key }}={{ rl.window }}"
{%- endif %}

{% endfor %}
{% endif %}

{% if blocked_endpoints %}
# --- Blocked endpoints -----------------------------------------------
{% for ep in blocked_endpoints %}
SecRule REQUEST_FILENAME "@rx {{ ep.regex }}" "id:{{ 30000 + loop.index0 }},phase:1,deny,status:403,log,t:none,t:normalizePath,msg:'Endpoint {{ ep.label }}'{% if ep.methods %},chain{% endif %}"
{%- if ep.methods %}
    SecRule REQUEST_METHOD "@rx ^({{ ep.methods }})$"
{%- endif %}
{% endfor %}
{% endif %}

{% if blocked_parameters %}
# --- Blocked parameters ----------------------------------------------
# Each rule chains: [endpoint] → parameter target → value match.
# When endpoint is empty the first chain link is omitted.
{% for bp in blocked_parameters %}
{% if bp.endpoint %}
SecRule REQUEST_FILENAME "@rx {{ bp.endpoint }}" \
    "id:{{ 40000 + loop.index0 }},phase:2,deny,status:403,log,chain,msg:'Parameter {{ bp.label }} blocked'"
    SecRule {{ bp.target }} "{{ bp.operator }}{% if bp.match_value %} {{ bp.match_value }}{% endif %}"
{% else %}
SecRule {{ bp.target }} "{{ bp.operator }}{% if bp.match_value %} {{ bp.match_value }}{% endif %}" \
    "id:{{ 40000 + loop.index0 }},phase:2,deny,status:403,log,msg:'Parameter {{ bp.label }} blocked'"
{% endif %}
{% endfor %}
{% endif %}

{% if request_limits %}
# --- Request limits --------------------------------------------------
{% for rl in request_limits %}
{% if rl.limit_type == "Body Size" %}
{% if rl.endpoint %}
SecRule REQUEST_FILENAME "@rx {{ rl.endpoint }}" \
    "id:{{ 60000 + loop.index0 }},phase:1,deny,status:413,log,chain,msg:'Request body too large (limit {{ rl.value }} bytes)'"
    SecRule REQUEST_BODY_LENGTH "@gt {{ rl.value }}"
{% else %}
SecRule REQUEST_BODY_LENGTH "@gt {{ rl.value }}" \
    "id:{{ 60000 + loop.index0 }},phase:1,deny,status:413,log,msg:'Request body too large (limit {{ rl.value }} bytes)'"
{% endif %}
{% else %}
{% if rl.endpoint %}
SecRule REQUEST_FILENAME "@rx {{ rl.endpoint }}" \
    "id:{{ 60000 + loop.index0 }},phase:1,deny,status:431,log,chain,msg:'Request headers too large (limit {{ rl.value }} bytes)'"
    SecRule REQUEST_HEADERS_LENGTH "@gt {{ rl.value }}"
{% else %}
SecRule REQUEST_HEADERS_LENGTH "@gt {{ rl.value }}" \
    "id:{{ 60000 + loop.index0 }},phase:1,deny,status:431,log,msg:'Request headers too large (limit {{ rl.value }} bytes)'"
{% endif %}
{% endif %}
{% endfor %}
{% endif %}

{% if custom_rules %}
# --- Custom ModSecurity rules (user-supplied) ------------------------
{% for c in custom_rules %}
# {{ c.rule_name }}
{{ c.rule_text }}
{% endfor %}
{% endif %}